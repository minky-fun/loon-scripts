[Script]
http-response ^https?:\/\/api\.(ainitpz|4hnovel|1000gxf)\.com\/App\/Resource\/Config\/getNav script-path=https://raw.githubusercontent.com/yangmingqi123/loon-scripts/main/TilingSales_getNav.js, requires-body=true, timeout=60
http-response ^https?:\/\/api\.(ainitpz|4hnovel|1000gxf)\.com\/App\/Ad\/barsPlayAdInfo script-path=https://raw.githubusercontent.com/yangmingqi123/loon-scripts/main/TilingSales_getNav.js, requires-body=true, timeout=60
http-response ^https?:\/\/api\.(ainitpz|4hnovel|1000gxf)\.com\/App\/Ad\/playAdInfo script-path=https://raw.githubusercontent.com/yangmingqi123/loon-scripts/main/TilingSales_getNav.js, requires-body=true, timeout=60
http-response ^https?:\/\/api\.(ainitpz|4hnovel|1000gxf)\.com\/App\/IndexPlay\/vodAdvertisement script-path=https://raw.githubusercontent.com/yangmingqi123/loon-scripts/main/TilingSales_getNav.js, requires-body=true, timeout=60
http-response ^https?:\/\/api\.(ainitpz|4hnovel|1000gxf)\.com\/App\/Resource\/Vod\/showOne script-path=https://raw.githubusercontent.com/yangmingqi123/loon-scripts/main/TilingSales_getNav.js, requires-body=true, timeout=60
http-response ^https?:\/\/api\.(ainitpz|4hnovel|1000gxf)\.com\/App\/Resource\/Vod\/vurlDetail script-path=https://raw.githubusercontent.com/yangmingqi123/loon-scripts/main/TilingSales_getNav.js, requires-body=true, timeout=60
http-response ^https?:\/\/api\.(ainitpz|4hnovel|1000gxf)\.com\/App\/Resource\/AppUserVod\/showOne script-path=https://raw.githubusercontent.com/yangmingqi123/loon-scripts/main/TilingSales_getNav.js, requires-body=true, timeout=60

