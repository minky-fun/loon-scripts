#!name=YouTube 评论翻译器（GPT）
#!desc=拦截并翻译 YouTube 评论为中文，使用 GPT 接口
#!author=Minky
#!homepage=https://github.com/yangmingqi123
#!icon=https://www.youtube.com/s/desktop/8cfc17a7/img/favicon.ico
#!date=2025 年 6 月 3 日 17:20:44

#!input=GPT_API_KEY
#!input=GPT_PROXY_URL

[mitm]
hostname = youtubei.googleapis.com

[Script]
# 插件入口，重写 youtube next 接口请求到你的代理服务器
^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/next$ url 302 http://your-server-ip:8080
