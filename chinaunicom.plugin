#!name=联通Cookie获取
#!desc=打开中国联通APP自动获取10010.cookie
#!system=ios

[Script]
http-request ^https:\/\/m\.client\.10010\.com\/mobileserviceNine\/api\/v1\/index\/queryCfig(\?.*)?$ script-path=https://raw.githubusercontent.com/yangmingqi123/loon-scripts/main/chinaunicom_cookie.js, requires-body=false, timeout=10, tag=联通Cookie获取

[MITM]
hostname = %APPEND% m.client.10010.com
