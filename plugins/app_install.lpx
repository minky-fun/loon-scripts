#!name=应用安装
#!desc=App Store 低版本应用安装、已购下架应用安装
#!author=Minky
#!homepage=https://github.com/minky-fun/loon-scripts
#!icon=https://raw.githubusercontent.com/minky-fun/loon-scripts/main/assets/loon_scripts_logo.png
#!tag=minky

[Script]
http-request ^https:\/\/apple-api\.com script-path=https://raw.githubusercontent.com/minky-fun/loon-scripts/main/scripts/AppleStoreAPI.js, requires-body=true, timeout=30, tag=应用接口
http-request ^https:\/\/xiaobai\.app script-path=https://raw.githubusercontent.com/minky-fun/loon-scripts/main/scripts/installapp.js, requires-body=false, timeout=60, tag=应用安装

[Mitm]
hostname = %APPEND% apple-api.com, xiaobai.app
