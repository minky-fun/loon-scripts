#!name=黑料网净化
#!desc=黑料纯享版，黑料不打烊，去恶心的开屏，首页各种乱七八糟的玩意。
#!author=ZenmoFeiShi[https://raw.githubusercontent.com/ZenmoFeiShi/Qx/refs/heads/main/hlwxx_remove_ads.snippet]
#!date=2025-04-18
#!openUrl=https://www.hlwxx.com，https://heiliao.com
#!homepage=https://github.com/ZenmoFeiShi
#!icon=

[Rewrite]
^https?:\/\/stats\.kwvprfcr\.xyz reject
^https?:\/\/mc\.yandex\.ru reject
^https?:\/\/api1\.cghhqca\.cc\/api\/eventTracking reject-dict

[Mitm]
hostname = *heiliao*, *hlwxx*, *hlcx*, stats.kwvprfcr.xyz, mc.yandex.ru, api1.cghhqca.cc

[Script]
http-response ^https?:\/\/(?:www\.)?(?:heiliao|hlwxx|hlcx\d*)\.com\/(?!static\/|favicon|api\/|index\/statistics|uploads\/) script-path=https://raw.githubusercontent.com/ZenmoFeiShi/Qx/refs/heads/main/hlwxx_remove_ads.js, requires-body=true, timeout=60, tag=黑料网去广告
