[Rule]
URL-REGEX,^https?:\/\/(autoload\.bank\.ecitic\.com\/imcslego|imcs\.citicbank\.com)\/cloud\/\w+\.png\?width=([1-9]\d{0,2}|1[0-2]\d\d|1300)&height=(1[5-9]\d\d|2[0-6]\d\d),REJECT

[MITM]
hostname = autoload.bank.ecitic.com, imcs.citicbank.com
